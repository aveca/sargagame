# Redirections SEO — à la racine du site (public_html / www)
# Redirection www vers non-www (évite contenu dupliqué)
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteCond %{HTTP_HOST} ^www\.(sargasses-martinique\.com|sargasses-guadeloupe\.com)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]
</IfModule>

# Forcer HTTPS (si le serveur le gère en amont, ces règles ne s'appliquent pas)
<IfModule mod_rewrite.c>
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# Redirections 301 — anciennes URLs vers la nouvelle structure (SEO : récupère le jus)
<IfModule mod_rewrite.c>
# Anciennes pages plages/plage → accueil (SPA gère l'affichage)
RewriteRule ^plages/(.+)/?$ / [R=301,L]
RewriteRule ^plages/?$ / [R=301,L]
RewriteRule ^plage/(.+)/?$ / [R=301,L]
RewriteRule ^plage/?$ / [R=301,L]
# Anciennes pages plages-guadeloupe / plages-martinique → accueil
RewriteRule ^plages-guadeloupe/(.+)/?$ / [R=301,L]
RewriteRule ^plages-guadeloupe/?$ / [R=301,L]
RewriteRule ^plages-martinique/(.+)/?$ / [R=301,L]
RewriteRule ^plages-martinique/?$ / [R=301,L]
# Anciennes pages communes → accueil
RewriteRule ^communes/(.+)/?$ / [R=301,L]
RewriteRule ^communes/?$ / [R=301,L]
# Anciennes pages éditoriales → accueil
RewriteRule ^sante-et-science/?$ / [R=301,L]
RewriteRule ^sargasses-outre-mer/?$ / [R=301,L]
RewriteRule ^plages-sans-sargasses-martinique/?$ / [R=301,L]
RewriteRule ^plages-sans-sargasses-guadeloupe/?$ / [R=301,L]
RewriteRule ^previsions-bulletin-direct/?$ /previsions/ [R=301,L]
# Ancien landing
RewriteRule ^landing-v2\.html$ / [R=301,L]
</IfModule>

# SPA fallback : redirige les routes virtuelles vers index.html
# (nécessaire pour que /carte-sargasses/, /previsions/ etc. fonctionnent en accès direct)
<IfModule mod_rewrite.c>
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(?!api/|assets/|en/|beaches/|config/)(.*)$ /index.html [L]
</IfModule>

# Page 404 personnalisée
ErrorDocument 404 /404.html

# Cache-Control pour les assets statiques (SEO : vitesse de chargement)
<IfModule mod_expires.c>
ExpiresActive On
ExpiresByType text/html "access plus 0 seconds"
ExpiresByType text/css "access plus 1 year"
ExpiresByType application/javascript "access plus 1 year"
ExpiresByType image/jpeg "access plus 1 month"
ExpiresByType image/png "access plus 1 month"
ExpiresByType image/webp "access plus 1 month"
ExpiresByType image/svg+xml "access plus 1 month"
ExpiresByType application/json "access plus 1 hour"
</IfModule>

# Compression gzip (SEO : vitesse)
<IfModule mod_deflate.c>
AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# Trailing slash cohérent (optionnel) : pas de redirection pour éviter boucles avec SPA
# Les URLs /carte-sargasses et /carte-sargasses/ servent la même page.
