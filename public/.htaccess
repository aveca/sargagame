RewriteRule ^plage/anse-couleuvre/?$ /plages/anse-couleuvre/ [R=301,L]
RewriteRule ^plages-martinique/anse-couleuvre/?$ /plages/anse-couleuvre/ [R=301,L]

# --- Diamant ---
RewriteRule ^plage/diamant/?$ /plages/plage-du-diamant/ [R=301,L]
RewriteRule ^plage/plage-du-diamant/?$ /plages/plage-du-diamant/ [R=301,L]
RewriteRule ^plages-martinique/diamant/?$ /plages/plage-du-diamant/ [R=301,L]

# --- Anse Noire ---
RewriteRule ^plage/anse-noire/?$ /plages/anse-noire/ [R=301,L]
RewriteRule ^plages-martinique/anse-noire/?$ /plages/anse-noire/ [R=301,L]

# --- Anse Dufour ---
RewriteRule ^plage/anse-dufour/?$ /plages/anse-dufour/ [R=301,L]
RewriteRule ^plages-martinique/anse-dufour/?$ /plages/anse-dufour/ [R=301,L]

# --- Cap Chevalier ---
RewriteRule ^plage/cap-chevalier/?$ / [R=301,L]
RewriteRule ^plages-martinique/cap-chevalier/?$ / [R=301,L]

# --- Anse Tartane ---
RewriteRule ^plage/anse-tartane/?$ /plages/bourg-de-tartane/ [R=301,L]
RewriteRule ^plages-martinique/anse-tartane/?$ /plages/bourg-de-tartane/ [R=301,L]
RewriteRule ^plages-martinique/tartane/?$ /plages/bourg-de-tartane/ [R=301,L]

# =====================================================================
# MARTINIQUE — Editorial pages redirects
# =====================================================================
RewriteRule ^sante-et-science/?$ / [R=301,L]
RewriteRule ^sargasses-outre-mer/?$ / [R=301,L]
RewriteRule ^plages-sans-sargasses-martinique/?$ /plages-sans-sargasses/ [R=301,L]
RewriteRule ^previsions-bulletin-direct/?$ /previsions/ [R=301,L]

# =====================================================================

# 2026-06-16 : 4 règles « ^plages/<slug>/ → /plages/<slug>/ » (auto-ajoutées par
# seo-fix-404 le 2026-04-13) retirées. Ces slugs sont devenus de VRAIES plages GP
# (anse-laborde, plage-des-amandiers, plage-de-sainte-claire, plage-de-la-desirade-sud :
# servies 200 + au sitemap GP) → la règle les redirigeait vers elles-mêmes = no-op
# au mieux, boucle 301 au pire. Aucune cible à « réparer » → supprimées.
# CATCH-ALL — remaining old URLs that don't match specific rules → homepage
# These MUST come AFTER all specific redirects above
# =====================================================================

# Anciennes pages /plage/ (singulier) sans correspondance → accueil
RewriteRule ^plage/(.+)/?$ / [R=301,L]
RewriteRule ^plage/?$ / [R=301,L]

# /plages/ a désormais sa vraie page hub (générée par vite.config — "Toutes les
# plages") : plus de redirect accueil. Le sitemap la déclare, Google la voyait
# en "Duplicate, submitted URL not selected as canonical" à cause de l'ancien 301.
RewriteRule ^plages/?$ /plages/index.html [L]

# Anciennes pages plages-guadeloupe sans correspondance → accueil
RewriteRule ^plages-guadeloupe/(.+)/?$ / [R=301,L]
RewriteRule ^plages-guadeloupe/?$ / [R=301,L]

# Anciennes pages plages-martinique sans correspondance → accueil
RewriteRule ^plages-martinique/(.+)/?$ / [R=301,L]
RewriteRule ^plages-martinique/?$ / [R=301,L]

# Ancien landing
RewriteRule ^landing-v2\.html$ / [R=301,L]
# weekend.html : ancienne LP de capture email, orpheline (aucun lien app/email),
# self-canonical + au sitemap = page fine indexable. Consolidée vers l'accueil
# (capture email désormais in-app). Retirée du sitemap (vite.config). 2026-06-16.
RewriteRule ^weekend\.html$ / [R=301,L]
# /articles/* : 2 bilans hebdomadaires avril 2026 — contenu daté, consolidé vers
# /previsions/ (le flux hebdomadaire vivant). Retirés sitemap (vide index.json). 2026-06-16.
RewriteRule ^articles/(.*)$ /previsions/ [R=301,L]
# Pages legacy HTML (noindex ou canonical croisé) — consolidées. 2026-06-16.
# onboarding.html : ancien onboarding abandonné (noindex), jamais lié depuis l'app.
RewriteRule ^onboarding\.html$ / [R=301,L]
# neptunes_fury.html : mini-jeu prototype (noindex), sans lien actif depuis l'app.
RewriteRule ^neptunes_fury\.html$ / [R=301,L]
# sarg_carte_satellite_app.html : ancienne carte satellite standalone (canonical → /carte-sargasses/).
RewriteRule ^sarg_carte_satellite_app\.html$ /carte-sargasses/ [R=301,L]
</IfModule>

# =====================================================================
# FILET DE SÉCURITÉ — page Fiabilité générée au build (reliability-page.cjs)
# Slugs : /fiabilite/ (FR — MQ + miroir _gp GP), /reliability/ (EN régions),
#         /fiabilidad/ (ES régions). Écrites dans dist/ à CHAQUE build, MAIS
# generateReliabilityPages() tourne sous un try/catch qui n'avale l'erreur
# qu'en console.warn (vite.config.js) : un throw du générateur = build vert
# = déploiement SANS la page. Sans ce filet, le SPA catch-all ci-dessous sert
# alors l'app shell (index.html) à la place — état CONSTATÉ en prod le
# 2026-06-16 sur sargassumpuntacana.com/fiabilidad/ (HTTP 200 mais id="root").
# Or /a-propos/ (paywall trust page) pointe 2× vers /fiabilite/ : sans filet,
# ces liens tombent sur l'app, pas sur une page de confiance.
#
# !-f / !-d : la règle NE TIRE JAMAIS quand la page existe (le dossier généré
# est servi tel quel) — elle ne masque donc jamais la vraie page. Quand elle
# manque → /a-propos/, page de confiance committée dans public/ (donc toujours
# déployée, jamais générée au build), vérifiée live HTTP 200 sur les 5 domaines
# le 2026-06-16, et qui porte le même récit méthode/backtest.
#
# 302 (temporaire) et NON 301 : l'absence est TRANSITOIRE (glitch de build).
# Un 301 serait caché par le navigateur ET désindexerait la vraie URL côté
# Google en la consolidant vers /a-propos/ ; au retour de la page, les clients
# resteraient coincés sur la redirection. Le 302 garde l'URL d'origine indexée
# et force un re-check. (cf. règle projet : ne jamais 301 un chemin qui PEUT
# être servi — leçon /a-propos/ masquée par un 301 legacy, 2026-06-10.)
# =====================================================================
<IfModule mod_rewrite.c>
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(fiabilite|reliability|fiabilidad)/?$ /a-propos/ [R=302,L]
</IfModule>

# SPA fallback : redirige les routes virtuelles vers index.html
# (nécessaire pour que /carte-sargasses/, /previsions/ etc. fonctionnent en accès direct)
<IfModule mod_rewrite.c>
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(?!api/|assets/|en/|beaches/|config/|plages/)(.*)$ /index.html [L]
</IfModule>

# Page 404 personnalisée
ErrorDocument 404 /404.html

# Cache-Control pour les assets statiques (SEO : vitesse de chargement)
<IfModule mod_headers.c>
# Hashed assets (JS/CSS fingerprintes) — immutable 1 an.
# IMPORTANT : exclure sw.js du lookahead, SINON le service worker est cache 1 an et les
# users restent coinces sur l'ancien bundle (= bug "clic plages" juin 2026, cause racine).
<FilesMatch "^(?!sw\.js$).+\.(js|css)$">
Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>
# Polices content-hashées (anton-*.woff2, bricolagegrotesque-*.woff2) — immutable 1 an.
# Exclues de la règle js|css ci-dessus → elles tombaient sur le défaut mod_expires (1h via
# le host), donc re-validées à chaque visite des 136 landing SEO (où le SW n'est pas installé).
<FilesMatch "\.woff2?$">
Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>
# sw.js + version.json JAMAIS caches. Place EN DERNIER pour ecraser toute regle ci-dessus
# (Header set = le dernier qui matche gagne). Double securite avec le lookahead ci-dessus.
<FilesMatch "(sw\.js|version\.json)$">
Header set Cache-Control "no-cache, no-store, must-revalidate"
Header set Pragma "no-cache"
Header set Expires "0"
</FilesMatch>
</IfModule>

<IfModule mod_expires.c>
ExpiresActive On
ExpiresByType text/html "access plus 0 seconds"
ExpiresByType text/css "access plus 1 year"
ExpiresByType application/javascript "access plus 1 year"
ExpiresByType image/jpeg "access plus 1 month"
ExpiresByType image/png "access plus 1 month"
ExpiresByType image/webp "access plus 1 month"
ExpiresByType image/svg+xml "access plus 1 month"
ExpiresByType application/json "access plus 1 hour"
ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# Compression gzip (SEO : vitesse)
<IfModule mod_deflate.c>
AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
# Compression Brotli (~15-20% de mieux que gzip sur JS/CSS/HTML/JSON). DEFLATE reste le
# fallback ci-dessus ; Vary: Accept-Encoding déjà posé (section headers). NB : LiteSpeed/
# Cloudflare gèrent souvent brotli en amont (panel/edge) → cette directive peut être un
# no-op. Vérifier en prod : curl -H 'Accept-Encoding: br' -I https://… | grep -i content-encoding
<IfModule mod_brotli.c>
AddOutputFilterByType BROTLI_COMPRESS text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# Trailing slash cohérent : redirige les URLs sans slash vers avec slash (évite contenu dupliqué)
<IfModule mod_rewrite.c>
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_URI} !/$
RewriteCond %{REQUEST_URI} !\.
RewriteRule ^(carte-sargasses|previsions|alertes|en|saison-sargasses-martinique|saison-sargasses-guadeloupe|plages-sans-sargasses|danger-sargasses-h2s|comprendre-sargasses|bilan-sargasses-2025|detection-satellite-sargasses|previsions-methode|nettoyer-sargasses|sargasses-record-2026)$ /$1/ [R=301,L]
</IfModule>

# Security headers (trust signals SEO + sécurité)
<IfModule mod_headers.c>
Header set X-Frame-Options "SAMEORIGIN"
Header set X-Content-Type-Options "nosniff"
Header set Referrer-Policy "strict-origin-when-cross-origin"
Header append Vary Accept-Encoding
</IfModule>

AddDefaultCharset UTF-8
