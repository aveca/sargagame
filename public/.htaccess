# Redirections SEO — à la racine du site (public_html / www)
# Redirection www vers non-www (évite contenu dupliqué)
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteCond %{HTTP_HOST} ^www\.(sargasses-martinique\.com|sargasses-guadeloupe\.com)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]
</IfModule>

# Forcer HTTPS (si le serveur le gère en amont, ces règles ne s'appliquent pas)
<IfModule mod_rewrite.c>
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# Redirections 301 — anciennes URLs vers la nouvelle structure (SEO : récupère le jus)
<IfModule mod_rewrite.c>

# =====================================================================
# GUADELOUPE — Smart redirects : /plages-guadeloupe/{old} → /plages/{new}
# Specific rules FIRST, catch-all LAST
# =====================================================================

# --- Malendure ---
RewriteRule ^plages-guadeloupe/plage-de-malendure/?$ /plages/plage-de-malendure/ [R=301,L]
RewriteRule ^plages-guadeloupe/malendure/?$ /plages/plage-de-malendure/ [R=301,L]
RewriteRule ^plages/malendure-bouillante/?$ /plages/plage-de-malendure/ [R=301,L]

# --- Grande Anse (Bouillante) ---
RewriteRule ^plages-guadeloupe/plage-de-grande-anse/?$ /plages/plage-de-grande-anse/ [R=301,L]
RewriteRule ^plages-guadeloupe/grande-anse/?$ /plages/plage-de-grande-anse/ [R=301,L]
RewriteRule ^plages-guadeloupe/grande-anse-bouillante/?$ /plages/plage-de-grande-anse/ [R=301,L]
RewriteRule ^plages/grande-anse/?$ /plages/plage-de-grande-anse/ [R=301,L]

# --- Sainte-Anne ---
RewriteRule ^plages-guadeloupe/plage-de-sainte-anne/?$ /plages/plage-de-sainte-anne/ [R=301,L]
RewriteRule ^plages-guadeloupe/sainte-anne/?$ /plages/plage-de-sainte-anne/ [R=301,L]
RewriteRule ^plages-guadeloupe/plage-du-bourg-de-sainte-anne/?$ /plages/plage-de-sainte-anne/ [R=301,L]
RewriteRule ^plages/sainte-anne/?$ /plages/plage-de-sainte-anne/ [R=301,L]

# --- Pointe des Châteaux ---
RewriteRule ^plages-guadeloupe/pointe-des-chateaux/?$ /plages/pointe-des-chateaux/ [R=301,L]
RewriteRule ^plages-guadeloupe/plage-des-grandes-salines/?$ /plages/pointe-des-chateaux/ [R=301,L]
RewriteRule ^plages-guadeloupe/anse-a-la-gourde/?$ /plages/pointe-des-chateaux/ [R=301,L]
RewriteRule ^plages/pointe-des-chateaux-saint-francois/?$ /plages/pointe-des-chateaux/ [R=301,L]

# --- Le Gosier ---
RewriteRule ^plages-guadeloupe/plage-du-gosier/?$ /plages/plage-du-gosier/ [R=301,L]
RewriteRule ^plages-guadeloupe/le-gosier/?$ /plages/plage-du-gosier/ [R=301,L]
RewriteRule ^plages-guadeloupe/plage-de-petit-havre/?$ /plages/plage-du-gosier/ [R=301,L]
RewriteRule ^plages-guadeloupe/petit-havre/?$ /plages/plage-du-gosier/ [R=301,L]
RewriteRule ^plages/gosier-plage/?$ /plages/plage-du-gosier/ [R=301,L]
RewriteRule ^plages/le-gosier-plage/?$ /plages/plage-du-gosier/ [R=301,L]

# --- Plage Caravelle ---
RewriteRule ^plages-guadeloupe/la-caravelle/?$ /plages/plage-de-la-caravelle/ [R=301,L]
RewriteRule ^plages-guadeloupe/plage-de-la-caravelle/?$ /plages/plage-de-la-caravelle/ [R=301,L]
RewriteRule ^plages-guadeloupe/caravelle/?$ /plages/plage-de-la-caravelle/ [R=301,L]
RewriteRule ^plages/la-caravelle/?$ /plages/plage-de-la-caravelle/ [R=301,L]
RewriteRule ^plages/caravelle/?$ /plages/plage-de-la-caravelle/ [R=301,L]
RewriteRule ^plages/caravelle-sainte-anne/?$ /plages/plage-de-la-caravelle/ [R=301,L]

# --- Bas du Fort ---
RewriteRule ^plages-guadeloupe/plage-de-bas-du-fort/?$ /plages/plage-de-bas-du-fort/ [R=301,L]
RewriteRule ^plages-guadeloupe/bas-du-fort/?$ /plages/plage-de-bas-du-fort/ [R=301,L]
RewriteRule ^plages/bas-du-fort-gosier/?$ /plages/plage-de-bas-du-fort/ [R=301,L]

# --- Grande Anse (Deshaies) ---
RewriteRule ^plages-guadeloupe/plage-de-grande-anse-deshaies/?$ /plages/la-grande-anse-deshaies/ [R=301,L]
RewriteRule ^plages-guadeloupe/grande-anse-deshaies/?$ /plages/la-grande-anse-deshaies/ [R=301,L]
RewriteRule ^plages-guadeloupe/deshaies/?$ /plages/la-grande-anse-deshaies/ [R=301,L]
RewriteRule ^plages/grande-anse-deshaies-plage/?$ /plages/la-grande-anse-deshaies/ [R=301,L]

# --- Plage Souffleur ---
RewriteRule ^plages-guadeloupe/plage-du-souffleur/?$ /plages/plage-du-souffleur/ [R=301,L]
RewriteRule ^plages-guadeloupe/souffleur/?$ /plages/plage-du-souffleur/ [R=301,L]
RewriteRule ^plages-guadeloupe/plage-du-souffleur-port-louis/?$ /plages/plage-du-souffleur/ [R=301,L]
RewriteRule ^plages/souffleur/?$ /plages/plage-du-souffleur/ [R=301,L]
RewriteRule ^plages/souffleur-port-louis/?$ /plages/plage-du-souffleur/ [R=301,L]

# --- Anse de la Gourde ---
RewriteRule ^plages-guadeloupe/vieux-fort/?$ /plages/anse-a-la-gourde/ [R=301,L]
RewriteRule ^plages-guadeloupe/anse-de-la-gourde/?$ /plages/anse-a-la-gourde/ [R=301,L]
RewriteRule ^plages/anse-de-la-gourde-saint-francois/?$ /plages/anse-a-la-gourde/ [R=301,L]

# =====================================================================
# GUADELOUPE — Communes → nearest new beach page
# =====================================================================
RewriteRule ^communes/deshaies/?$ /plages/la-grande-anse-deshaies/ [R=301,L]
RewriteRule ^communes/bouillante/?$ /plages/plage-de-grande-anse/ [R=301,L]
RewriteRule ^communes/sainte-anne/?$ /plages/plage-de-sainte-anne/ [R=301,L]
RewriteRule ^communes/saint-francois/?$ /plages/pointe-des-chateaux/ [R=301,L]
RewriteRule ^communes/le-gosier/?$ /plages/plage-du-gosier/ [R=301,L]
RewriteRule ^communes/gosier/?$ /plages/plage-du-gosier/ [R=301,L]
RewriteRule ^communes/port-louis/?$ /plages/plage-du-souffleur/ [R=301,L]
RewriteRule ^communes/petit-bourg/?$ / [R=301,L]
RewriteRule ^communes/sainte-rose/?$ / [R=301,L]
RewriteRule ^communes/baie-mahault/?$ / [R=301,L]
# Catch-all communes
RewriteRule ^communes/(.+)/?$ / [R=301,L]
RewriteRule ^communes/?$ / [R=301,L]

# =====================================================================
# GUADELOUPE — Editorial pages redirects
# =====================================================================
RewriteRule ^carte-temps-reel/?$ /carte-sargasses/ [R=301,L]
RewriteRule ^methode-carte/?$ /carte-sargasses/ [R=301,L]
RewriteRule ^previsions-sargasses-guadeloupe/?$ /previsions/ [R=301,L]
RewriteRule ^faq/?$ / [R=301,L]
RewriteRule ^cgu/?$ /mentions-legales.html [R=301,L]
RewriteRule ^mentions-legales/?$ /mentions-legales.html [R=301,L]
RewriteRule ^politique-de-confidentialite/?$ /confidentialite.html [R=301,L]
RewriteRule ^contact/?$ / [R=301,L]
RewriteRule ^a-propos/?$ / [R=301,L]
RewriteRule ^premium/?$ / [R=301,L]
RewriteRule ^quand-sargasses-guadeloupe/?$ /saison-sargasses-guadeloupe/ [R=301,L]
RewriteRule ^plages-deshaies-guadeloupe/?$ /plages/la-grande-anse-deshaies/ [R=301,L]
RewriteRule ^plages-saint-francois-guadeloupe/?$ /plages/plage-de-la-caravelle/ [R=301,L]
RewriteRule ^plages-sans-sargasses-guadeloupe/?$ /plages-sans-sargasses/ [R=301,L]

# --- GSC 404 fixes: beaches crawled but not in current list → nearest match ---
RewriteRule ^plages/anse-a-la-fontaine/?$ /plages/anse-champagne/ [R=301,L]
RewriteRule ^plages/paul-thomas/?$ /plages/plage-de-sainte-anne/ [R=301,L]
RewriteRule ^plages-guadeloupe/plage-d-anse-champagne/?$ /plages/anse-champagne/ [R=301,L]
RewriteRule ^plages/petite-anse-du-diamant/?$ /plages/anse-cafard/ [R=301,L]

# =====================================================================
# MARTINIQUE — Smart redirects : old /plage(s)/{old} → /plages/{new}
# =====================================================================

# --- Grande Anse d'Arlet ---
RewriteRule ^plage/grande-anse-darlet/?$ /plages/grande-anse-d-arlet/ [R=301,L]
RewriteRule ^plage/grande-anse/?$ /plages/grande-anse-d-arlet/ [R=301,L]
RewriteRule ^plage/grande-anse-d-arlet/?$ /plages/grande-anse-d-arlet/ [R=301,L]
RewriteRule ^plages-martinique/grande-anse/?$ /plages/grande-anse-d-arlet/ [R=301,L]
RewriteRule ^plages-martinique/grande-anse-darlet/?$ /plages/grande-anse-d-arlet/ [R=301,L]

# --- Anse Mitan ---
RewriteRule ^plage/anse-mitan/?$ /plages/anse-mitan/ [R=301,L]
RewriteRule ^plages-martinique/anse-mitan/?$ /plages/anse-mitan/ [R=301,L]

# --- Les Salines ---
RewriteRule ^plage/les-salines/?$ /plages/plage-des-salines/ [R=301,L]
RewriteRule ^plage/salines/?$ /plages/plage-des-salines/ [R=301,L]
RewriteRule ^plages-martinique/les-salines/?$ /plages/plage-des-salines/ [R=301,L]
RewriteRule ^plages-martinique/salines/?$ /plages/plage-des-salines/ [R=301,L]

# --- Anse Couleuvre ---
RewriteRule ^plage/anse-couleuvre/?$ /plages/anse-couleuvre/ [R=301,L]
RewriteRule ^plages-martinique/anse-couleuvre/?$ /plages/anse-couleuvre/ [R=301,L]

# --- Diamant ---
RewriteRule ^plage/diamant/?$ /plages/plage-du-diamant/ [R=301,L]
RewriteRule ^plage/plage-du-diamant/?$ /plages/plage-du-diamant/ [R=301,L]
RewriteRule ^plages-martinique/diamant/?$ /plages/plage-du-diamant/ [R=301,L]

# --- Anse Noire ---
RewriteRule ^plage/anse-noire/?$ /plages/anse-noire/ [R=301,L]
RewriteRule ^plages-martinique/anse-noire/?$ /plages/anse-noire/ [R=301,L]

# --- Anse Dufour ---
RewriteRule ^plage/anse-dufour/?$ /plages/anse-dufour/ [R=301,L]
RewriteRule ^plages-martinique/anse-dufour/?$ /plages/anse-dufour/ [R=301,L]

# --- Cap Chevalier ---
RewriteRule ^plage/cap-chevalier/?$ / [R=301,L]
RewriteRule ^plages-martinique/cap-chevalier/?$ / [R=301,L]

# --- Anse Tartane ---
RewriteRule ^plage/anse-tartane/?$ /plages/bourg-de-tartane/ [R=301,L]
RewriteRule ^plages-martinique/anse-tartane/?$ /plages/bourg-de-tartane/ [R=301,L]
RewriteRule ^plages-martinique/tartane/?$ /plages/bourg-de-tartane/ [R=301,L]

# =====================================================================
# MARTINIQUE — Editorial pages redirects
# =====================================================================
RewriteRule ^sante-et-science/?$ / [R=301,L]
RewriteRule ^sargasses-outre-mer/?$ / [R=301,L]
RewriteRule ^plages-sans-sargasses-martinique/?$ /plages-sans-sargasses/ [R=301,L]
RewriteRule ^previsions-bulletin-direct/?$ /previsions/ [R=301,L]

# =====================================================================
# CATCH-ALL — remaining old URLs that don't match specific rules → homepage
# These MUST come AFTER all specific redirects above
# =====================================================================

# Anciennes pages /plage/ (singulier) sans correspondance → accueil
RewriteRule ^plage/(.+)/?$ / [R=301,L]
RewriteRule ^plage/?$ / [R=301,L]

# /plages/ sans slug → accueil (les /plages/{slug}/ sont gérées par les fichiers statiques)
RewriteRule ^plages/?$ / [R=301,L]

# Anciennes pages plages-guadeloupe sans correspondance → accueil
RewriteRule ^plages-guadeloupe/(.+)/?$ / [R=301,L]
RewriteRule ^plages-guadeloupe/?$ / [R=301,L]

# Anciennes pages plages-martinique sans correspondance → accueil
RewriteRule ^plages-martinique/(.+)/?$ / [R=301,L]
RewriteRule ^plages-martinique/?$ / [R=301,L]

# Ancien landing
RewriteRule ^landing-v2\.html$ / [R=301,L]
</IfModule>

# SPA fallback : redirige les routes virtuelles vers index.html
# (nécessaire pour que /carte-sargasses/, /previsions/ etc. fonctionnent en accès direct)
<IfModule mod_rewrite.c>
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(?!api/|assets/|en/|beaches/|config/|plages/)(.*)$ /index.html [L]
</IfModule>

# Page 404 personnalisée
ErrorDocument 404 /404.html

# Cache-Control pour les assets statiques (SEO : vitesse de chargement)
# sw.js + version.json JAMAIS cachés — sinon les users restent bloqués sur l'ancienne version
<IfModule mod_headers.c>
<FilesMatch "(sw\.js|version\.json)$">
Header set Cache-Control "no-cache, no-store, must-revalidate"
Header set Pragma "no-cache"
Header set Expires "0"
</FilesMatch>
</IfModule>

# Hashed assets (JS/CSS in /assets/) — immutable, cache 1 year
# The "immutable" directive tells browsers AND Cloudflare to never revalidate
<IfModule mod_headers.c>
<FilesMatch "\.(js|css)$">
Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>
</IfModule>

<IfModule mod_expires.c>
ExpiresActive On
ExpiresByType text/html "access plus 0 seconds"
ExpiresByType text/css "access plus 1 year"
ExpiresByType application/javascript "access plus 1 year"
ExpiresByType image/jpeg "access plus 1 month"
ExpiresByType image/png "access plus 1 month"
ExpiresByType image/webp "access plus 1 month"
ExpiresByType image/svg+xml "access plus 1 month"
ExpiresByType application/json "access plus 1 hour"
</IfModule>

# Compression gzip (SEO : vitesse)
<IfModule mod_deflate.c>
AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# Trailing slash cohérent : redirige les URLs sans slash vers avec slash (évite contenu dupliqué)
<IfModule mod_rewrite.c>
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_URI} !/$
RewriteCond %{REQUEST_URI} !\.
RewriteRule ^(carte-sargasses|previsions|alertes|en|saison-sargasses-martinique|saison-sargasses-guadeloupe|plages-sans-sargasses|danger-sargasses-h2s)$ /$1/ [R=301,L]
</IfModule>

# Security headers (trust signals SEO + sécurité)
<IfModule mod_headers.c>
Header set X-Frame-Options "SAMEORIGIN"
Header set X-Content-Type-Options "nosniff"
Header set Referrer-Policy "strict-origin-when-cross-origin"
Header append Vary Accept-Encoding
</IfModule>

AddDefaultCharset UTF-8
